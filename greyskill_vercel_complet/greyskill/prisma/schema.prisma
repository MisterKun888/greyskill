// GreySkill — Schéma Prisma complet
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// UTILISATEURS
// ========================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  nom           String
  prenom        String
  telephone     String?
  role          Role      @default(CLIENT)
  passwordHash  String
  avatar        String?
  adresse       String?
  ville         String?
  pays          String    @default("FR")
  langue        String    @default("fr")
  devise        String    @default("EUR")
  stripeCustomerId String?
  kycStatus     KYCStatus @default(PENDING)
  kycDocumentUrl String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profilSenior  ProfilSenior?
  missionsClient Mission[]    @relation("ClientMissions")
  candidatures  Candidature[]
  messagesEnvoyes Message[]   @relation("MessagesSent")
  notesRecues   Note[]        @relation("NotesRecues")
  notesEmises   Note[]        @relation("NotesEmises")
  paiements     Paiement[]
  litiges       Litige[]      @relation("LitigesClient")

  @@map("users")
}

enum Role {
  CLIENT
  SENIOR
  ADMIN
}

enum KYCStatus {
  PENDING
  VALIDATED
  REJECTED
}

// ========================
// PROFIL SENIOR
// ========================
model ProfilSenior {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  age             Int
  bio             String?
  competences     String[] // Array de compétences
  passions        String[] // Passions monétisables
  categories      String[] // Catégories de métiers
  tarifHoraire    Float
  tarifDevis      Boolean  @default(false) // Si tarif sur devis
  portfolio       String[] // URLs portfolio
  experienceAns   Int
  certification   Certification @default(NOUVEAU)
  nbMissions      Int      @default(0)
  noteMoyenne     Float    @default(0)
  // Géolocalisation
  latitude        Float?
  longitude       Float?
  rayonKm         Int      @default(10)
  // Stripe Connect
  stripeAccountId String?
  stripeOnboarded Boolean  @default(false)
  // Auto-entrepreneur
  siret           String?
  numeroAutoEntrepreneur String?
  // Abonnement
  abonnement      AbonnementSenior @default(GRATUIT)
  abonnementExpiry DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  missionsAssignees Mission[] @relation("SeniorMissions")
  candidatures      Candidature[]

  @@map("profils_seniors")
}

enum Certification {
  NOUVEAU
  CONFIRME
  BRONZE
  ARGENT
  OR
}

enum AbonnementSenior {
  GRATUIT
  CONFIRME
  ELITE
}

// ========================
// MISSIONS
// ========================
model Mission {
  id          String        @id @default(cuid())
  titre       String
  description String
  categorie   String
  budget      Float
  devise      String        @default("EUR")
  dureeEstimee String?
  localisation String?
  latitude    Float?
  longitude   Float?
  remote      Boolean       @default(false)
  statut      MissionStatut @default(OUVERTE)
  // Relations
  clientId    String
  client      User          @relation("ClientMissions", fields: [clientId], references: [id])
  seniorId    String?
  senior      ProfilSenior? @relation("SeniorMissions", fields: [seniorId], references: [id])
  // Stripe
  stripePaymentIntentId String?
  stripeSessionId       String?
  montantPaye   Float?
  commission    Float?
  montantSenior Float?
  // Dates
  dateDebut   DateTime?
  dateFin     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  candidatures Candidature[]
  messages     Message[]
  notes        Note[]
  litige       Litige?
  paiements    Paiement[]

  @@map("missions")
}

enum MissionStatut {
  OUVERTE
  ASSIGNEE
  EN_COURS
  TERMINEE_CLIENT
  TERMINEE_SENIOR
  TERMINEE
  ANNULEE
  LITIGE
}

// ========================
// CANDIDATURES
// ========================
model Candidature {
  id          String             @id @default(cuid())
  missionId   String
  mission     Mission            @relation(fields: [missionId], references: [id])
  seniorId    String
  senior      ProfilSenior       @relation(fields: [seniorId], references: [id])
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  message     String
  tarif       Float?
  statut      CandidatureStatut  @default(EN_ATTENTE)
  createdAt   DateTime           @default(now())

  @@unique([missionId, seniorId])
  @@map("candidatures")
}

enum CandidatureStatut {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

// ========================
// MESSAGERIE INTERNE
// ========================
model Message {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id])
  senderId  String
  sender    User     @relation("MessagesSent", fields: [senderId], references: [id])
  contenu   String
  bloque    Boolean  @default(false) // Message contournement bloqué
  typeMedia String?  // "text", "file", "image"
  mediaUrl  String?
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages")
}

// ========================
// NOTES & AVIS
// ========================
model Note {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id])
  auteurId  String
  auteur    User     @relation("NotesEmises", fields: [auteurId], references: [id])
  cibleId   String
  cible     User     @relation("NotesRecues", fields: [cibleId], references: [id])
  rating    Int      // 1-5
  commentaire String?
  createdAt DateTime @default(now())

  @@unique([missionId, auteurId])
  @@map("notes")
}

// ========================
// PAIEMENTS
// ========================
model Paiement {
  id                    String        @id @default(cuid())
  missionId             String
  mission               Mission       @relation(fields: [missionId], references: [id])
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  stripePaymentIntentId String        @unique
  montantTotal          Float
  commission            Float
  montantSenior         Float
  devise                String        @default("EUR")
  statut                PaiementStatut @default(SEQUESTRE)
  dateCapture           DateTime?
  createdAt             DateTime      @default(now())

  @@map("paiements")
}

enum PaiementStatut {
  SEQUESTRE
  CAPTURE
  LIBERE
  REMBOURSE
  PARTIEL
}

// ========================
// LITIGES
// ========================
model Litige {
  id          String      @id @default(cuid())
  missionId   String      @unique
  mission     Mission     @relation(fields: [missionId], references: [id])
  clientId    String
  client      User        @relation("LitigesClient", fields: [clientId], references: [id])
  motif       String
  description String
  preuves     String[]    // URLs des preuves
  statut      LitigeStatut @default(OUVERT)
  scoreIA     Float?       // Score 0-1 calculé par l'IA
  montantRembourse Float?
  resolution  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("litiges")
}

enum LitigeStatut {
  OUVERT
  EN_ANALYSE
  RESOLU
  REJETE
}

// ========================
// ABONNEMENTS
// ========================
model Abonnement {
  id              String   @id @default(cuid())
  userId          String
  type            String   // "senior_elite", "client_pro", etc.
  stripeSubId     String   @unique
  statut          String   @default("active")
  dateDebut       DateTime
  dateFin         DateTime?
  createdAt       DateTime @default(now())

  @@map("abonnements")
}
